// secrets.h.example
// Copy this file to secrets.h and fill in your credentials.
// secrets.h is gitignored and will never be committed.
//
// NOTE: With the web UI, you no longer need to hardcode credentials here.
//       All settings are configurable via the setup portal (first boot)
//       and the Settings page at http://<board-ip>
//
// This file is kept for reference only.

// WiFi credentials
#define WIFI_SSID     "your-wifi-network"
#define WIFI_PASS     "your-wifi-password"

// HiveMQ Cloud MQTT
#define MQTT_HOST     "xxxx.s1.eu.hivemq.cloud"
#define MQTT_USER     "your-mqtt-username"
#define MQTT_PASS     "your-mqtt-password"
